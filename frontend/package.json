    "formik": "^2.4.9",
    "i18n-iso-countries": "^7.14.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "react-use": "^17.6.0",
    "reactstrap": "^9.2.3",
    "recharts": "^3.8.1",
    "sass": "^1.99.0",
